<%- include('../partials/head', { title: 'Админ-панель' }) %>

  <body>
    <%- include('../partials/header') %>

      <style>
        .admin-wrap {
          max-width: 1100px;
          margin: 40px auto;
          padding: 0 20px;
        }

        .admin-title {
          font-size: 2rem;
          font-weight: 700;
          margin-bottom: 8px;
        }

        .admin-subtitle {
          color: #888;
          margin-bottom: 32px;
        }

        .admin-section {
          background: #fff;
          border-radius: 16px;
          padding: 28px 32px;
          margin-bottom: 32px;
          box-shadow: 0 2px 16px rgba(0, 0, 0, .07);
        }

        .admin-section h2 {
          font-size: 1.3rem;
          font-weight: 600;
          margin-bottom: 20px;
          border-bottom: 2px solid #f0f0f0;
          padding-bottom: 12px;
        }

        .add-form {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 14px;
        }

        .add-form .full {
          grid-column: 1 / -1;
        }

        .add-form input,
        .add-form select,
        .add-form textarea {
          width: 100%;
          padding: 10px 14px;
          border: 1.5px solid #e0e0e0;
          border-radius: 10px;
          font-size: .95rem;
          background: #fafafa;
          box-sizing: border-box;
        }

        .add-form input:focus,
        .add-form select:focus {
          outline: none;
          border-color: #b08d67;
        }

        .add-form label {
          font-size: .85rem;
          color: #666;
          margin-bottom: 4px;
          display: block;
        }

        .btn {
          padding: 10px 22px;
          border-radius: 10px;
          border: none;
          cursor: pointer;
          font-size: .95rem;
          font-weight: 600;
          transition: opacity .2s;
        }

        .btn:hover {
          opacity: .85;
        }

        .btn-primary {
          background: #b08d67;
          color: #fff;
        }

        .btn-danger {
          background: #e74c3c;
          color: #fff;
          padding: 6px 14px;
          font-size: .82rem;
        }

        .btn-edit {
          background: #3498db;
          color: #fff;
          padding: 6px 14px;
          font-size: .82rem;
        }

        .photo-table {
          width: 100%;
          border-collapse: collapse;
        }

        .photo-table th {
          text-align: left;
          padding: 10px 12px;
          font-size: .82rem;
          color: #999;
          border-bottom: 2px solid #f0f0f0;
        }

        .photo-table td {
          padding: 10px 12px;
          border-bottom: 1px solid #f5f5f5;
          vertical-align: middle;
          font-size: .9rem;
        }

        .photo-table tr:hover td {
          background: #fafafa;
        }

        .photo-thumb {
          width: 60px;
          height: 48px;
          object-fit: cover;
          border-radius: 8px;
        }

        .or-divider {
          text-align: center;
          color: #aaa;
          font-size: .85rem;
          margin: 6px 0;
        }

        .flash {
          padding: 12px 16px;
          border-radius: 10px;
          margin-bottom: 20px;
        }

        .flash.success {
          background: #d4edda;
          color: #155724;
        }

        .flash.error {
          background: #f8d7da;
          color: #721c24;
        }

        @media(max-width:700px) {
          .add-form {
            grid-template-columns: 1fr;
          }
        }
      </style>

      <div class="admin-wrap">
        <div class="admin-title">Админ-панель</div>
        <div class="admin-subtitle">Управление фотографиями сайта</div>

        <% if (flash) { %>
          <div class="flash <%= flash.type %>">
            <%= flash.message %>
          </div>
          <% } %>

            <!-- ===== ADD PHOTO ===== -->
            <div class="admin-section">
              <h2>Добавить фото</h2>
              <form action="/admin/photos/add" method="POST" enctype="multipart/form-data">
                <div class="add-form">

                  <div>
                    <label>Категория *</label>
                    <select name="category" required>
                      <option value="">-- выберите --</option>
                      <option value="portrait">Портрет</option>
                      <option value="love">Love Story</option>
                      <option value="family">Семья</option>
                      <option value="event">Событие</option>
                    </select>
                  </div>

                  <div>
                    <label>Порядок сортировки</label>
                    <input type="number" name="sort" placeholder="0" min="0">
                  </div>

                  <div>
                    <label>Название *</label>
                    <input type="text" name="title" required placeholder="Например: Love Story #5">
                  </div>

                  <div>
                    <label>Подпись (необязательно)</label>
                    <input type="text" name="subtitle" placeholder="Краткое описание">
                  </div>

                  <div class="full">
                    <label>Загрузить файл с компьютера</label>
                    <input type="file" name="image" accept="image/*">
                    <div class="or-divider">— или —</div>
                    <label>Путь к файлу (например: /images/photo.jpg)</label>
                    <input type="text" name="imageUrl" placeholder="/images/my_photo.jpg">
                  </div>

                  <div class="full">
                    <button type="submit" class="btn btn-primary">Добавить фото</button>
                  </div>
                </div>
              </form>
            </div>

            <!-- ===== PHOTO LIST ===== -->
            <div class="admin-section">
              <h2>Все фото (<%= photos.length %>)</h2>
              <% if (photos.length===0) { %>
                <p style="color:#aaa">Нет фотографий.</p>
                <% } else { %>
                  <table class="photo-table">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Фото</th>
                        <th>Название</th>
                        <th>Категория</th>
                        <th>Подпись</th>
                        <th>Путь</th>
                        <th>Сортировка</th>
                        <th>Действия</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% photos.forEach(p=> { %>
                        <tr>
                          <td>
                            <%= p.id %>
                          </td>
                          <td><img src="<%= p.imagePath %>" alt="" class="photo-thumb"
                              onerror="this.style.opacity='.3'"></td>
                          <td>
                            <%= p.title %>
                          </td>
                          <td>
                            <%= p.category %>
                          </td>
                          <td>
                            <%= p.subtitle || '—' %>
                          </td>
                          <td
                            style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:.8rem;color:#888">
                            <%= p.imagePath %>
                          </td>
                          <td>
                            <%= p.sort %>
                          </td>
                          <td style="white-space:nowrap">
                            <a href="/admin/photos/<%= p.id %>/edit" class="btn btn-edit">Изменить</a>
                            <form action="/admin/photos/<%= p.id %>/delete" method="POST" style="display:inline"
                              onsubmit="return confirm('Удалить фото «<%= p.title %>»?')">
                              <button type="submit" class="btn btn-danger">Удалить</button>
                            </form>
                          </td>
                        </tr>
                        <% }) %>
                    </tbody>
                  </table>
                  <% } %>
            </div>

            <div class="admin-section">
              <h2>Отзывы на модерации (<%= pendingReviews.length %>)</h2>
              <% if (pendingReviews.length===0) { %>
                <p style="color:#aaa">Нет новых отзывов на проверке.</p>
                <% } else { %>
                  <table class="photo-table">
                    <thead>
                      <tr>
                        <th>Автор</th>
                        <th>Оценка</th>
                        <th>Текст</th>
                        <th>Действия</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% pendingReviews.forEach(r=> { %>
                        <tr>
                          <td><strong>
                              <%= r.name %>
                            </strong></td>
                          <td>
                            <% for (let i=1; i <=5; i++) { %>
                              <span style="color:<%= i <= r.rating ? '#f59e0b' : '#ddd' %>">★</span>
                              <% } %>
                          </td>
                          <td style="max-width:400px;word-break:break-word">
                            <%= r.text %>
                          </td>
                          <td style="white-space:nowrap;display:flex;gap:8px">
                            <form action="/admin/reviews/<%= r.id %>/approve" method="POST">
                              <button class="btn btn-edit" type="submit">Одобрить</button>
                            </form>
                            <form action="/admin/reviews/<%= r.id %>/delete" method="POST"
                              onsubmit="return confirm('Удалить отзыв?')">
                              <button class="btn btn-danger" type="submit">Удалить</button>
                            </form>
                          </td>
                        </tr>
                        <% }) %>
                    </tbody>
                  </table>
                  <% } %>
            </div>

            <div class="admin-section">
              <h2>Записи на съемку (<%= bookings.length %>)</h2>
              <% if (bookings.length===0) { %>
                <p style="color:#aaa">Нет записей на съемку.</p>
                <% } else { %>
                  <table class="photo-table">
                    <thead>
                      <tr>
                        <th>ID</th>
                        <th>Клиент</th>
                        <th>Телефон</th>
                        <th>Тариф</th>
                        <th>Дата</th>
                        <th>Время</th>
                        <th>Статус</th>
                        <th>Действия</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% bookings.forEach(b=> { %>
                        <tr>
                          <td>
                            <%= b.id %>
                          </td>
                          <td>
                            <strong>
                              <%= b.clientName %>
                            </strong><br>
                            <span style="color:#999;font-size:.85rem">
                              <%= b.User.name %> (<%= b.User.email %>)
                            </span>
                          </td>
                          <td>
                            <%= b.phone %>
                          </td>
                          <td>
                            <%= b.Certificate.title %>
                          </td>
                          <td>
                            <%= new Date(b.bookingDate).toLocaleDateString('ru-RU',
                              {day:'numeric',month:'short',year:'numeric'}) %>
                          </td>
                          <td>
                            <%= b.bookingTime %>
                          </td>
                          <td>
                            <% if (b.status==='new' ) { %>
                              <span class="status-badge" style="background:#fef3c7;color:#92400e">На рассмотрении</span>
                              <% } else if (b.status==='approved' ) { %>
                                <span class="status-badge" style="background:#dcfce7;color:#166534">✓
                                  Подтверждена</span>
                                <% } else if (b.status==='completed' ) { %>
                                  <span class="status-badge" style="background:#e6f4ff;color:#0b5394">Завершена</span>
                                  <% } else { %>
                                    <span class="status-badge" style="background:#fee2e2;color:#991b1b">✕
                                      Отклонена</span>
                                    <% } %>
                          </td>
                          <td style="white-space:nowrap;display:flex;gap:8px">
                            <% if (b.status==='new' ) { %>
                              <form action="/admin/bookings/<%= b.id %>/approve" method="POST" style="display:inline">
                                <button class="btn btn-edit" type="submit">Подтвердить</button>
                              </form>
                              <form action="/admin/bookings/<%= b.id %>/reject" method="POST" style="display:inline"
                                onsubmit="return confirm('Отклонить запись?')">
                                <button class="btn btn-danger" type="submit">Отклонить</button>
                              </form>
                              <% } else if (b.status==='approved' ) { %>
                                <form action="/admin/bookings/<%= b.id %>/complete" method="POST"
                                  style="display:inline">
                                  <button class="btn btn-primary" type="submit">Отметить как завершённую</button>
                                </form>
                                <% } %>
                          </td>
                        </tr>
                        <% }) %>
                    </tbody>
                  </table>
                  <% } %>
            </div>

      </div>

      <%- include('../partials/footer') %>
        <script src="/js/script.js"></script>
  </body>

  </html>