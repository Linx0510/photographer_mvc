<div id="chatWidget" class="chat-widget">
  <button id="chatToggleBtn" class="chat-toggle-btn" title="ИИ Ассистент">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
  </button>

  <div id="chatPanel" class="chat-panel">
    <div class="chat-header">
      <h3>ИИ Ассистент</h3>
      <button id="chatCloseBtn" class="chat-close-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div id="chatMessages" class="chat-messages">
      <div class="chat-message bot">
        <div class="message-content">Привет! 👋 Я могу рассказать о доступных датах и ценах на фотосессии. Что вас интересует?</div>
      </div>
    </div>

    <div class="chat-input-area">
      <input
        type="text"
        id="chatInput"
        class="chat-input"
        placeholder="Введите ваш вопрос..."
        autocomplete="off"
      />
      <button id="chatSendBtn" class="chat-send-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>
  </div>
</div>
